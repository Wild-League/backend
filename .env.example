# Django
SECRET_KEY=your-secret-key
DJANGO_SETTINGS_MODULE=src.config.dev_settings

# Postmark (email)
POSTMARK_TOKEN=token

# PostgreSQL (used by postgres container, api, and nakama)
# For Docker: use POSTGRES_HOST=postgres
# Default DB (POSTGRES_DB) is used by api; nakama uses database "nakama" (created via init script)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=wildleague

# SeaweedFS S3-compatible storage
# For Docker: use SEAWEED_S3_ENDPOINT=seaweedfs-s3:8333
SEAWEED_S3_ENDPOINT=seaweedfs-s3:8333
SEAWEED_PUBLIC_BASE_URL=http://localhost:8333
SEAWEED_ACCESS_KEY=wildleague
SEAWEED_SECRET_KEY=wildleague-secret
# Bucket for default card PNGs (seed_default_cards mirrors GitHub → S3 on first run)
SEAWEED_CARD_BUCKET=cards
# URL prefix clients use to load images (set when S3_ENDPOINT is internal, e.g. Docker)
# SEAWEED_PUBLIC_BASE_URL=http://localhost:8333

# Base URL for card image paths when running: python manage.py seed_default_cards
# Default is raw GitHub for https://github.com/Wild-League/base-cards-assets (main)
# CARD_ASSET_BASE_URL=https://raw.githubusercontent.com/Wild-League/base-cards-assets/main

# App URL and domain
URL=http://localhost:8000
DOMAIN=@wildleague.org
